{{- if eq .osid "linux-fedora" -}}

{{ $packages := list
     "zsh"
     "@development-tools"
     "golang"
     "pipx"
     "tmux" -}}

{{ $coprRepos := list
     "@go-sig/golang-rawhide" -}}

{{ $sudo := "sudo " -}}
{{ if eq .chezmoi.username "root" -}}
{{   $sudo = "" -}}
{{ end -}}

#!/bin/bash

set -eufo pipefail

# Enable COPR repositories
{{ range $coprRepos -}}
{{ $sudo }}dnf copr enable -y {{ . }}
{{ end }}

# Install packages
{{ $sudo }}dnf install -y {{ $packages | join " " }}

{{ end -}}
{{/* vim: set ft=bash ts=2 sw=2 et:  */}}
